# Copie para .env e preencha os valores.
# Nunca commite o arquivo .env.

SECRET_KEY=change-me-in-production
DJANGO_ENV=dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Perfil dev-docker (Docker Compose) ---
# Use quando rodar: docker compose up -d
DATABASE_URL=postgres://marryme:marryme@db:5432/marryme
REDIS_URL=redis://redis:6379/0

# --- Perfil dev-sqlite (venv local, sem Docker) ---
# Comente ou remova DATABASE_URL e REDIS_URL para usar SQLite + broker em memória
# DATABASE_URL=
# REDIS_URL=

# Integrações (opcionais em dev)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
APIFY_API_TOKEN=

# URL do frontend (links de convite do portal)
FRONTEND_URL=http://localhost:3000
CONVITE_EXPIRACAO_HORAS=48
LOG_LEVEL=INFO

# Gunicorn (produção)
PORT=8000

# Produção (Railway: DJANGO_ENV=prod no serviço web)
# SECURE_SSL_REDIRECT=True
# ALLOWED_HOSTS=web-production-xxx.up.railway.app
# (healthcheck.railway.app é adicionado automaticamente em prod.py)
# CORS_ALLOWED_ORIGINS=https://seu-projeto.vercel.app,https://marryme.com.br
# FRONTEND_URL=https://seu-projeto.vercel.app
